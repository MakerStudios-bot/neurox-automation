# Neurox Bot Provisioner - Environment Variables Example
# Copy this file to .env and fill in your actual values

# REQUIRED: Railway API Token for cloning projects
# Get it from: https://railway.app/dashboard/settings
RAILWAY_API_TOKEN=your_railway_api_token_here

# OPTIONAL: Railway API URL (defaults to public API)
RAILWAY_API_URL=https://api.railway.app/graphql

# OPTIONAL: Meta/Facebook credentials for Instagram integration
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_BUSINESS_ACCOUNT_ID=your_business_account_id

# OPTIONAL: Vendedor name that appears in the system
NEUROX_VENDEDOR_NOMBRE=María

# OPTIONAL: Server port (defaults to 3000)
PORT=8000

# OPTIONAL: Database path (defaults to neurox_provisioning.db)
# DB_PATH=./neurox_provisioning.db
